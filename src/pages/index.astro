---
import Layout from '../layouts/Layout.astro';
import stats from '../data/stats.json';
import pipeline from '../data/pipeline.json';

// Pipeline stages
const pipelineStages = [
  { id: 'new', label: 'New', color: 'status-new' },
  { id: 'researching', label: 'Researching', color: 'status-researching' },
  { id: 'qualified', label: 'Qualified', color: 'status-qualified' },
  { id: 'contacted', label: 'Contacted', color: 'status-contacted' },
  { id: 'rejected', label: 'Rejected', color: 'status-rejected' },
];

// Top pipeline prospects by score
const topProspects = [...pipeline]
  .filter(p => p.score && p.score > 0)
  .sort((a, b) => (b.score || 0) - (a.score || 0))
  .slice(0, 8);

// Recent activity - prospects with updates in the last 7 days
const recentActivity = [...pipeline]
  .filter(p => {
    if (p.dateUpdated) {
      const updateDate = new Date(p.dateUpdated);
      const sevenDaysAgo = new Date();
      sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7);
      return updateDate >= sevenDaysAgo;
    }
    return false;
  })
  .sort((a, b) => new Date(b.dateUpdated) - new Date(a.dateUpdated))
  .slice(0, 10);

// If no recent updates by date, show recently qualified prospects
const recentQualified = recentActivity.length === 0 ? 
  [...pipeline]
    .filter(p => p.stage === 'qualified' && p.score > 0)
    .sort((a, b) => (b.score || 0) - (a.score || 0))
    .slice(0, 6) : [];

// Pipeline by country
const regionEntries = Object.entries(stats.pipeline.byCountry || {})
  .sort((a, b) => b[1] - a[1]);

// Lead pool top countries
const lpCountries = Object.entries(stats.leadpool.byCountry || {})
  .sort((a, b) => b[1] - a[1])
  .slice(0, 8);
---

<Layout title="Dashboard" activeNav="dashboard">
  <div class="space-y-6">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-2">
      <div>
        <h2 class="text-2xl md:text-3xl font-bold" style="color: var(--text-primary);">Pipeline Dashboard</h2>
        <p class="text-sm md:text-base mt-1" style="color: var(--text-secondary);">ITAD Return Hub recruitment pipeline overview</p>
      </div>
      <div class="flex flex-col md:flex-row md:items-center gap-3">
        <span class="text-xs md:text-sm" style="color: var(--text-tertiary);">Last updated: {new Date(stats.lastUpdated).toLocaleDateString()}</span>
        <a href="/pipeline" class="btn-primary text-sm md:text-base mobile-touch-target text-center">View Pipeline</a>
      </div>
    </div>

    <!-- Pipeline Stats (Primary) -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
      <div class="stat-card mobile-tap-highlight" style="border-left: 3px solid var(--brand-green);">
        <div class="stat-value text-xl md:text-2xl" style="color: var(--brand-green);">{stats.pipeline.total}</div>
        <div class="stat-label text-xs md:text-sm">Researched Prospects</div>
      </div>
      <div class="stat-card mobile-tap-highlight">
        <div class="stat-value text-xl md:text-2xl">{stats.pipeline.avgScore}</div>
        <div class="stat-label text-xs md:text-sm">Average Score</div>
      </div>
      <div class="stat-card mobile-tap-highlight">
        <div class="stat-value text-xl md:text-2xl" style="color: var(--status-qualified);">{stats.pipeline.scoreDistribution.high}</div>
        <div class="stat-label text-xs md:text-sm">Score 80+</div>
      </div>
      <div class="stat-card mobile-tap-highlight">
        <div class="stat-value text-xl md:text-2xl">{stats.pipeline.topScore}</div>
        <div class="stat-label text-xs md:text-sm">Top Score</div>
      </div>
    </div>

    <!-- Lead Pool Stats (Secondary) -->
    <div class="card p-4 flex items-center gap-4" style="background: var(--bg-elevated); border-color: var(--border);">
      <div class="flex items-center gap-2">
        <div class="w-2.5 h-2.5 rounded-full" style="background: var(--status-unverified);"></div>
        <span class="text-sm" style="color: var(--text-secondary);">
          <strong style="color: var(--text-primary);">{stats.leadpool.total.toLocaleString()}+</strong> Unverified Leads (Certus Import)
        </span>
      </div>
      <span class="text-xs" style="color: var(--text-tertiary);">|</span>
      <span class="text-sm" style="color: var(--text-secondary);">
        <strong style="color: var(--text-primary);">{stats.totalContacts.toLocaleString()}</strong> Contacts
      </span>
      <div class="flex-1"></div>
      <a href="/leads" class="text-xs" style="color: var(--brand-green);">Browse Lead Pool</a>
    </div>

    <!-- Recent Activity -->
    <div class="card p-5">
      <div class="flex items-center justify-between mb-4">
        <div class="flex items-center gap-2">
          <h3 class="text-sm font-semibold" style="color: var(--text-primary);">Recent Activity</h3>
          <div class="w-2 h-2 rounded-full animate-pulse" style="background: var(--brand-green);"></div>
        </div>
        <a href="/pipeline" class="text-xs" style="color: var(--brand-green);">View All Changes</a>
      </div>
      <div class="space-y-1 md:space-y-2">
        {(recentActivity.length > 0 ? recentActivity : recentQualified).map(lead => (
          <a
            href={`/lead/${lead.slug}`}
            class="flex items-center justify-between py-3 md:py-2 px-3 md:px-2 rounded-lg md:rounded -mx-3 md:-mx-2 transition-colors mobile-touch-target mobile-tap-highlight"
            style="border-bottom: 1px solid var(--border);"
            onmouseover="this.style.background='var(--bg-elevated)'"
            onmouseout="this.style.background='transparent'"
          >
            <div class="min-w-0 flex items-center gap-3">
              <div class="flex flex-col">
                <span class={`score-badge mb-1 ${(lead.score || 0) >= 80 ? 'score-high' : (lead.score || 0) >= 70 ? 'score-mid' : 'score-low'}`}>{lead.score || '—'}</span>
                {recentActivity.length > 0 && lead.dateUpdated && (
                  <span class="text-xs px-1.5 py-0.5 rounded" style="background: rgba(45, 107, 63, 0.1); color: var(--brand-green);">
                    {new Date(lead.dateUpdated).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                  </span>
                )}
              </div>
              <div>
                <div class="text-sm font-medium truncate" style="color: var(--text-primary);">{lead.name}</div>
                <div class="text-xs truncate" style="color: var(--text-tertiary);">{lead.pipelineData?.flag || ''} {lead.country}</div>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <span class={`status-badge status-${lead.stage}`}>{lead.stage}</span>
              {recentActivity.length > 0 && (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--brand-green)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20,6 9,17 4,12"/>
                </svg>
              )}
            </div>
          </a>
        ))}
        {(recentActivity.length === 0 && recentQualified.length === 0) && (
          <div class="text-center py-6" style="color: var(--text-tertiary);">
            <div class="text-sm mb-1">No recent activity</div>
            <div class="text-xs">Pipeline updates will appear here</div>
          </div>
        )}
      </div>
      <div class="mt-3 pt-3 border-t text-xs" style="border-color: var(--border); color: var(--text-tertiary);">
        {recentActivity.length > 0 ? 
          `${recentActivity.length} prospects updated in the last 7 days` :
          `Showing ${recentQualified.length} recently qualified prospects`
        }
      </div>
    </div>

    <!-- Pipeline by Stage -->
    <div class="card p-5">
      <h3 class="text-sm font-semibold mb-4" style="color: var(--text-primary);">Pipeline by Stage</h3>
      <div class="space-y-3">
        {pipelineStages.map(stage => {
          const count = stats.pipeline.byStage[stage.id] || 0;
          const percentage = stats.pipeline.total > 0 ? (count / stats.pipeline.total * 100) : 0;
          return (
            <div class="flex items-center gap-4">
              <div class="w-28 text-sm" style="color: var(--text-secondary);">{stage.label}</div>
              <div class="flex-1 h-6 rounded-full overflow-hidden" style="background: var(--bg-elevated);">
                <div
                  class={`h-full rounded-full`}
                  style={`width: ${Math.max(percentage, 1)}%; background: var(--${stage.color});`}
                />
              </div>
              <div class="w-16 text-right text-sm font-medium" style="color: var(--text-primary);">{count}</div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- Two Column Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 md:gap-6">
      <!-- Top Prospects -->
      <div class="card p-5">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-sm font-semibold" style="color: var(--text-primary);">Top Prospects by Score</h3>
          <a href="/pipeline" class="text-xs" style="color: var(--brand-green);">View All</a>
        </div>
        <div class="space-y-1 md:space-y-2">
          {topProspects.map(lead => (
            <a
              href={`/lead/${lead.slug}`}
              class="flex items-center justify-between py-3 md:py-2 px-3 md:px-2 rounded-lg md:rounded -mx-3 md:-mx-2 transition-colors mobile-touch-target mobile-tap-highlight"
              style="border-bottom: 1px solid var(--border);"
              onmouseover="this.style.background='var(--bg-elevated)'"
              onmouseout="this.style.background='transparent'"
            >
              <div class="min-w-0 flex items-center gap-2">
                <span class={`score-badge ${(lead.score || 0) >= 80 ? 'score-high' : (lead.score || 0) >= 70 ? 'score-mid' : 'score-low'}`}>{lead.score}</span>
                <div>
                  <div class="text-sm font-medium truncate" style="color: var(--text-primary);">{lead.name}</div>
                  <div class="text-xs truncate" style="color: var(--text-tertiary);">{lead.pipelineData?.flag || ''} {lead.country}</div>
                </div>
              </div>
              <span class={`status-badge status-${lead.stage}`}>{lead.stage}</span>
            </a>
          ))}
        </div>
      </div>

      <!-- Pipeline by Country -->
      <div class="card p-5">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-sm font-semibold" style="color: var(--text-primary);">Pipeline by Country</h3>
          <a href="/map" class="text-xs" style="color: var(--brand-green);">View Map</a>
        </div>
        <div class="space-y-2">
          {regionEntries.slice(0, 7).map(([region, count]) => (
            <div class="flex items-center justify-between py-1.5 border-b" style="border-color: var(--border);">
              <span class="text-sm" style="color: var(--text-secondary);">{region}</span>
              <span class="text-sm font-medium" style="color: var(--text-primary);">{count}</span>
            </div>
          ))}
          <div id="country-remaining-items" class="space-y-2" style="display: none;">
            {regionEntries.slice(7).map(([region, count]) => (
              <div class="flex items-center justify-between py-1.5 border-b" style="border-color: var(--border);">
                <span class="text-sm" style="color: var(--text-secondary);">{region}</span>
                <span class="text-sm font-medium" style="color: var(--text-primary);">{count}</span>
              </div>
            ))}
          </div>
          {regionEntries.length > 7 && (
            <button 
              id="country-toggle-btn"
              class="w-full mt-3 py-2 px-3 rounded-lg text-sm transition-colors border"
              style="color: var(--brand-green); border-color: var(--border); background: transparent;"
              onmouseover="this.style.background='var(--bg-elevated)'"
              onmouseout="this.style.background='transparent'"
            >
              <span id="country-show-text">Show {regionEntries.length - 7} more countries</span>
              <span id="country-hide-text" style="display: none;">Show fewer countries</span>
              <svg id="country-chevron-down" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline ml-1">
                <polyline points="6,9 12,15 18,9"></polyline>
              </svg>
              <svg id="country-chevron-up" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline ml-1" style="display: none;">
                <polyline points="18,15 12,9 6,15"></polyline>
              </svg>
            </button>
          )}
        </div>
        <div class="mt-3 pt-3 border-t" style="border-color: var(--border);">
          <span class="text-xs" style="color: var(--text-tertiary);">
            {Object.keys(stats.byCountry).length} countries total across pipeline + lead pool
          </span>
        </div>
      </div>
    </div>

    <!-- Charts Section -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 md:gap-6">
      <!-- Pipeline Stage Chart -->
      <div class="card p-4 md:p-5">
        <h3 class="text-sm md:text-base font-semibold mb-4" style="color: var(--text-primary);">Pipeline Stages</h3>
        <div class="h-56 md:h-64 flex items-center justify-center">
          <canvas id="stageChart" width="250" height="250"></canvas>
        </div>
      </div>

      <!-- Score Distribution Chart -->
      <div class="card p-4 md:p-5">
        <h3 class="text-sm md:text-base font-semibold mb-4" style="color: var(--text-primary);">Score Distribution</h3>
        <div class="h-56 md:h-64 flex items-center justify-center">
          <canvas id="scoreChart" width="250" height="200"></canvas>
        </div>
      </div>
    </div>

    <!-- Score Distribution (Legacy Grid) -->
    <div class="card p-4 md:p-5">
      <h3 class="text-sm md:text-base font-semibold mb-4" style="color: var(--text-primary);">Score Breakdown</h3>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 md:gap-4">
        <div class="p-3 rounded" style="background: rgba(45, 107, 63, 0.1);">
          <div class="text-lg font-semibold" style="color: var(--status-qualified);">{stats.pipeline.scoreDistribution.high}</div>
          <div class="text-xs" style="color: var(--text-tertiary);">Score 80+ (High fit)</div>
        </div>
        <div class="p-3 rounded" style="background: rgba(217, 119, 6, 0.1);">
          <div class="text-lg font-semibold" style="color: #D97706;">{stats.pipeline.scoreDistribution.medium}</div>
          <div class="text-xs" style="color: var(--text-tertiary);">Score 70-79 (Good fit)</div>
        </div>
        <div class="p-3 rounded" style="background: rgba(231, 76, 60, 0.1);">
          <div class="text-lg font-semibold" style="color: var(--status-rejected);">{stats.pipeline.scoreDistribution.low}</div>
          <div class="text-xs" style="color: var(--text-tertiary);">Score &lt;70 (Needs review)</div>
        </div>
        <div class="p-3 rounded" style="background: var(--bg-elevated);">
          <div class="text-lg font-semibold" style="color: var(--text-secondary);">{stats.pipeline.scoreDistribution.unscored}</div>
          <div class="text-xs" style="color: var(--text-tertiary);">Unscored</div>
        </div>
      </div>
    </div>

    <!-- Data Quality Notice -->
    <div class="card p-4 flex items-start gap-3" style="background: rgba(251, 191, 36, 0.1); border-color: rgba(251, 191, 36, 0.3);">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#FBBF24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mt-0.5">
        <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
      <div>
        <div class="text-sm font-medium" style="color: var(--text-primary);">Data Sources</div>
        <p class="text-xs mt-1" style="color: var(--text-secondary);">
          <strong>{stats.pipeline.total} pipeline prospects</strong> are hand-researched and scored by Returna.
          The remaining <strong>{stats.leadpool.total.toLocaleString()} leads</strong> are raw imports from Certus Software's Pipedrive CRM and have not been independently verified. Lead pool data may be outdated or incorrect.
        </p>
      </div>
    </div>
  </div>
</Layout>

<!-- Chart.js CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.js"></script>

<script is:inline define:vars={{ statsData: stats }}>
document.addEventListener('DOMContentLoaded', function() {
  // Get theme-aware colors
  function getThemeColors() {
    const theme = document.documentElement.getAttribute('data-theme') || 'dark';
    return theme === 'dark' ? {
      text: '#f1f5f9',
      textSecondary: '#94a3b8',
      grid: '#334155',
      background: 'rgba(30, 41, 59, 0.8)'
    } : {
      text: '#1e293b',
      textSecondary: '#64748b',
      grid: '#e2e8f0',
      background: 'rgba(255, 255, 255, 0.8)'
    };
  }

  // Pipeline Stage Chart (Doughnut)
  function createStageChart() {
    const ctx = document.getElementById('stageChart');
    if (!ctx) return;
    
    const colors = getThemeColors();
    const stageData = statsData.pipeline.byStage;
    
    new Chart(ctx, {
      type: 'doughnut',
      data: {
        labels: ['Qualified', 'New', 'Researching', 'Contacted', 'Rejected'],
        datasets: [{
          data: [
            stageData.qualified || 0,
            stageData.new || 0, 
            stageData.researching || 0,
            stageData.contacted || 0,
            stageData.rejected || 0
          ],
          backgroundColor: [
            '#2D6B3F', // qualified - green
            '#3B82F6', // new - blue
            '#8B5CF6', // researching - purple
            '#E67E22', // contacted - orange
            '#E74C3C'  // rejected - red
          ],
          borderWidth: 2,
          borderColor: colors.background
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            position: 'bottom',
            labels: {
              color: colors.text,
              padding: 15,
              usePointStyle: true,
              font: { size: 11 }
            }
          },
          tooltip: {
            backgroundColor: colors.background,
            titleColor: colors.text,
            bodyColor: colors.text,
            borderColor: colors.grid,
            borderWidth: 1
          }
        }
      }
    });
  }

  // Score Distribution Chart (Bar)
  function createScoreChart() {
    const ctx = document.getElementById('scoreChart');
    if (!ctx) return;
    
    const colors = getThemeColors();
    const scoreData = statsData.pipeline.scoreDistribution;
    
    new Chart(ctx, {
      type: 'bar',
      data: {
        labels: ['80+', '70-79', '<70', 'Unscored'],
        datasets: [{
          label: 'Prospects',
          data: [
            scoreData.high || 0,
            scoreData.medium || 0, 
            scoreData.low || 0,
            scoreData.unscored || 0
          ],
          backgroundColor: [
            '#2D6B3F', // high - green
            '#D97706', // medium - orange
            '#E74C3C', // low - red
            '#64748B'  // unscored - gray
          ],
          borderWidth: 0,
          borderRadius: 4
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            display: false
          },
          tooltip: {
            backgroundColor: colors.background,
            titleColor: colors.text,
            bodyColor: colors.text,
            borderColor: colors.grid,
            borderWidth: 1
          }
        },
        scales: {
          y: {
            beginAtZero: true,
            ticks: {
              color: colors.textSecondary,
              font: { size: 11 }
            },
            grid: {
              color: colors.grid,
              lineWidth: 0.5
            }
          },
          x: {
            ticks: {
              color: colors.textSecondary,
              font: { size: 11 }
            },
            grid: {
              display: false
            }
          }
        }
      }
    });
  }

  // Initialize charts
  createStageChart();
  createScoreChart();

  // Re-create charts on theme change
  let charts = [];
  const observer = new MutationObserver(function(mutations) {
    mutations.forEach(function(mutation) {
      if (mutation.type === 'attributes' && mutation.attributeName === 'data-theme') {
        // Destroy existing charts
        Chart.getChart('stageChart')?.destroy();
        Chart.getChart('scoreChart')?.destroy();
        // Recreate with new theme
        setTimeout(() => {
          createStageChart();
          createScoreChart();
        }, 100);
      }
    });
  });
  
  observer.observe(document.documentElement, { 
    attributes: true, 
    attributeFilter: ['data-theme'] 
  });

  // Country list toggle functionality
  const toggleBtn = document.getElementById('country-toggle-btn');
  const remainingItems = document.getElementById('country-remaining-items');
  const showText = document.getElementById('country-show-text');
  const hideText = document.getElementById('country-hide-text');
  const chevronDown = document.getElementById('country-chevron-down');
  const chevronUp = document.getElementById('country-chevron-up');
  
  let isExpanded = false;

  if (toggleBtn) {
    toggleBtn.addEventListener('click', function() {
      isExpanded = !isExpanded;
      
      if (isExpanded) {
        remainingItems.style.display = 'block';
        showText.style.display = 'none';
        hideText.style.display = 'inline';
        chevronDown.style.display = 'none';
        chevronUp.style.display = 'inline';
      } else {
        remainingItems.style.display = 'none';
        showText.style.display = 'inline';
        hideText.style.display = 'none';
        chevronDown.style.display = 'inline';
        chevronUp.style.display = 'none';
      }
    });
  }
});
</script>
