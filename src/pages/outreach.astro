---
import Layout from '../layouts/Layout.astro';
import pipeline from '../data/pipeline.json';

// Get qualified companies sorted by score, then new/researching
const qualified = pipeline
  .filter(org => org.stage === 'qualified')
  .sort((a, b) => (b.score || 0) - (a.score || 0));

const contacted = pipeline.filter(org => org.stage === 'contacted');
const newOrgs = pipeline.filter(org => org.stage === 'new' || org.stage === 'researching');

// Top outreach candidates: qualified with contacts and high scores
const readyForOutreach = qualified.filter(org => org.contacts && org.contacts.length > 0);
const noContacts = qualified.filter(org => !org.contacts || org.contacts.length === 0);

// Region breakdown of ready candidates
const byRegion = readyForOutreach.reduce((acc, org) => {
  const r = org.region || 'Unknown';
  if (!acc[r]) acc[r] = [];
  acc[r].push(org);
  return acc;
}, {} as Record<string, typeof readyForOutreach>);

const regionOrder = Object.entries(byRegion)
  .sort((a, b) => b[1].length - a[1].length);

// Score tiers
const tier1 = readyForOutreach.filter(o => (o.score || 0) >= 80);
const tier2 = readyForOutreach.filter(o => (o.score || 0) >= 70 && (o.score || 0) < 80);
const tier3 = readyForOutreach.filter(o => (o.score || 0) < 70);
---

<Layout title="Outreach Planner" activeNav="outreach">
  <div class="space-y-6">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <div>
        <h2 class="text-2xl font-bold" style="color: var(--text-primary);">Outreach Planner</h2>
        <p class="text-sm mt-1" style="color: var(--text-secondary);">
          {readyForOutreach.length} companies ready for outreach · {contacted.length} already contacted
        </p>
      </div>
      <div class="flex items-center gap-3">
        <button id="export-csv" class="btn-secondary text-sm flex items-center gap-2">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          Export CSV
        </button>
      </div>
    </div>

    <!-- Summary Cards -->
    <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
      <div class="card p-4 text-center">
        <div class="text-2xl font-bold" style="color: var(--brand-green);">{tier1.length}</div>
        <div class="text-xs mt-1" style="color: var(--text-tertiary);">Tier 1 (80+)</div>
        <div class="text-[10px]" style="color: var(--text-tertiary);">Priority targets</div>
      </div>
      <div class="card p-4 text-center">
        <div class="text-2xl font-bold" style="color: var(--status-researching);">{tier2.length}</div>
        <div class="text-xs mt-1" style="color: var(--text-tertiary);">Tier 2 (70-79)</div>
        <div class="text-[10px]" style="color: var(--text-tertiary);">Strong candidates</div>
      </div>
      <div class="card p-4 text-center">
        <div class="text-2xl font-bold" style="color: var(--text-secondary);">{tier3.length}</div>
        <div class="text-xs mt-1" style="color: var(--text-tertiary);">Tier 3 (&lt;70)</div>
        <div class="text-[10px]" style="color: var(--text-tertiary);">Worth exploring</div>
      </div>
      <div class="card p-4 text-center">
        <div class="text-2xl font-bold" style="color: var(--status-contacted);">{contacted.length}</div>
        <div class="text-xs mt-1" style="color: var(--text-tertiary);">Contacted</div>
        <div class="text-[10px]" style="color: var(--text-tertiary);">In progress</div>
      </div>
      <div class="card p-4 text-center">
        <div class="text-2xl font-bold" style="color: var(--status-rejected);">{noContacts.length}</div>
        <div class="text-xs mt-1" style="color: var(--text-tertiary);">No Contacts</div>
        <div class="text-[10px]" style="color: var(--text-tertiary);">Need research</div>
      </div>
    </div>

    <!-- Filters -->
    <div class="card p-4">
      <div class="flex flex-wrap items-center gap-3">
        <label class="text-sm font-medium" style="color: var(--text-secondary);">Filter:</label>
        <select id="region-filter" class="input text-sm" style="width: auto;">
          <option value="all">All Regions</option>
          {regionOrder.map(([region, orgs]) => (
            <option value={region}>{region} ({orgs.length})</option>
          ))}
        </select>
        <select id="tier-filter" class="input text-sm" style="width: auto;">
          <option value="all">All Tiers</option>
          <option value="tier1">Tier 1 (80+)</option>
          <option value="tier2">Tier 2 (70-79)</option>
          <option value="tier3">Tier 3 (&lt;70)</option>
        </select>
        <input type="search" id="outreach-search" class="input text-sm" placeholder="Search..." style="width: 180px;" />
      </div>
    </div>

    <!-- Outreach Table -->
    <div class="card overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm" id="outreach-table">
          <thead>
            <tr style="background: var(--bg-tertiary);">
              <th class="text-left p-3 font-medium" style="color: var(--text-secondary); min-width: 40px;">#</th>
              <th class="text-left p-3 font-medium cursor-pointer hover-underline" style="color: var(--text-secondary);" data-sort="score">Score ↓</th>
              <th class="text-left p-3 font-medium" style="color: var(--text-secondary);">Company</th>
              <th class="text-left p-3 font-medium" style="color: var(--text-secondary);">Region</th>
              <th class="text-left p-3 font-medium" style="color: var(--text-secondary);">Contact</th>
              <th class="text-left p-3 font-medium" style="color: var(--text-secondary);">Email</th>
              <th class="text-left p-3 font-medium" style="color: var(--text-secondary);">Actions</th>
            </tr>
          </thead>
          <tbody>
            {readyForOutreach.map((org, idx) => {
              const contact = org.contacts[0];
              const tierClass = (org.score || 0) >= 80 ? 'tier1' : (org.score || 0) >= 70 ? 'tier2' : 'tier3';
              return (
                <tr class={`outreach-row border-t ${tierClass}`} style="border-color: var(--border);"
                    data-region={org.region || 'Unknown'}
                    data-score={org.score || 0}
                    data-name={org.name.toLowerCase()}
                    data-email={contact?.email || ''}
                    data-contact-name={contact?.name || ''}
                    data-company={org.name}
                    data-website={org.website || ''}>
                  <td class="p-3" style="color: var(--text-tertiary);">{idx + 1}</td>
                  <td class="p-3">
                    <span class={`inline-flex items-center justify-center w-8 h-8 rounded-full text-xs font-bold ${
                      (org.score || 0) >= 80 ? '' : (org.score || 0) >= 70 ? '' : ''
                    }`} style={`background: ${(org.score || 0) >= 80 ? 'rgba(45, 107, 63, 0.15)' : (org.score || 0) >= 70 ? 'rgba(139, 92, 246, 0.15)' : 'rgba(100,100,100,0.15)'}; color: ${(org.score || 0) >= 80 ? 'var(--brand-green)' : (org.score || 0) >= 70 ? 'var(--status-researching)' : 'var(--text-secondary)'};`}>
                      {org.score}
                    </span>
                  </td>
                  <td class="p-3">
                    <a href={`/lead/${org.slug}`} class="font-medium hover:underline" style="color: var(--text-primary);">{org.name}</a>
                    {org.website && (
                      <a href={`https://${org.website}`} target="_blank" class="ml-1 text-xs" style="color: var(--text-tertiary);">↗</a>
                    )}
                  </td>
                  <td class="p-3" style="color: var(--text-secondary);">{org.region || '-'}</td>
                  <td class="p-3">
                    <div style="color: var(--text-primary);">{contact?.name || '-'}</div>
                    <div class="text-xs" style="color: var(--text-tertiary);">{contact?.title || ''}</div>
                  </td>
                  <td class="p-3">
                    {contact?.email ? (
                      <a href={`mailto:${contact.email}`} class="text-xs hover:underline" style="color: var(--brand-green);">{contact.email}</a>
                    ) : (
                      <span class="text-xs" style="color: var(--text-tertiary);">-</span>
                    )}
                  </td>
                  <td class="p-3">
                    <div class="flex items-center gap-1">
                      {contact?.email && (
                        <button class="draft-email-btn p-1.5 rounded hover:opacity-80" style="background: rgba(45, 107, 63, 0.1); color: var(--brand-green);" title="Generate email draft"
                          data-company={org.name} data-contact={contact.name} data-email={contact.email} data-website={org.website || ''}>
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
                          </svg>
                        </button>
                      )}
                      {contact?.linkedin && (
                        <a href={contact.linkedin} target="_blank" class="p-1.5 rounded hover:opacity-80" style="background: rgba(59, 130, 246, 0.1); color: rgb(59, 130, 246);" title="LinkedIn">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                          </svg>
                        </a>
                      )}
                    </div>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>

    <!-- No Contacts Section -->
    {noContacts.length > 0 && (
      <div class="card p-4">
        <h3 class="font-semibold mb-3" style="color: var(--text-primary);">
          ⚠️ Qualified but no contacts ({noContacts.length})
          <span class="text-xs font-normal ml-2" style="color: var(--text-tertiary);">Need contact research before outreach</span>
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-2">
          {noContacts.sort((a, b) => (b.score || 0) - (a.score || 0)).map(org => (
            <a href={`/lead/${org.slug}`} class="flex items-center gap-2 p-2 rounded hover:opacity-80" style="background: var(--bg-tertiary);">
              <span class="text-xs font-bold w-6 text-center" style={`color: ${(org.score || 0) >= 80 ? 'var(--brand-green)' : 'var(--status-researching)'};`}>{org.score}</span>
              <span class="text-sm" style="color: var(--text-primary);">{org.name}</span>
              <span class="text-xs ml-auto" style="color: var(--text-tertiary);">{org.region}</span>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Email Draft Modal -->
    <div id="email-modal" class="fixed inset-0 z-40 hidden" style="background: rgba(0,0,0,0.5);">
      <div class="flex items-center justify-center min-h-screen p-4">
        <div class="card p-6 max-w-2xl w-full" style="max-height: 90vh; overflow-y: auto;">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-semibold" style="color: var(--text-primary);">Email Draft</h3>
            <button id="close-modal" class="p-1 rounded hover:opacity-80" style="color: var(--text-tertiary);">✕</button>
          </div>
          <div class="space-y-3">
            <div>
              <label class="text-xs font-medium" style="color: var(--text-tertiary);">To:</label>
              <div id="modal-to" class="text-sm" style="color: var(--text-primary);"></div>
            </div>
            <div>
              <label class="text-xs font-medium" style="color: var(--text-tertiary);">Subject:</label>
              <input id="modal-subject" class="input text-sm w-full" />
            </div>
            <div>
              <label class="text-xs font-medium" style="color: var(--text-tertiary);">Body:</label>
              <textarea id="modal-body" class="input text-sm w-full" rows="12" style="font-family: inherit; line-height: 1.6;"></textarea>
            </div>
            <div class="flex items-center gap-2 pt-2">
              <button id="copy-email" class="btn-primary text-sm">Copy to Clipboard</button>
              <a id="mailto-link" href="#" class="btn-secondary text-sm">Open in Email Client</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Filters
    const regionFilter = document.getElementById('region-filter') as HTMLSelectElement;
    const tierFilter = document.getElementById('tier-filter') as HTMLSelectElement;
    const searchInput = document.getElementById('outreach-search') as HTMLInputElement;
    const rows = document.querySelectorAll('.outreach-row') as NodeListOf<HTMLTableRowElement>;

    function applyFilters() {
      const region = regionFilter.value;
      const tier = tierFilter.value;
      const search = searchInput.value.toLowerCase();
      let visibleIdx = 0;

      rows.forEach(row => {
        const rowRegion = row.dataset.region || '';
        const rowScore = parseInt(row.dataset.score || '0');
        const rowName = row.dataset.name || '';
        const rowEmail = row.dataset.email || '';
        const rowContact = row.dataset.contactName || '';

        let show = true;
        if (region !== 'all' && rowRegion !== region) show = false;
        if (tier === 'tier1' && rowScore < 80) show = false;
        if (tier === 'tier2' && (rowScore < 70 || rowScore >= 80)) show = false;
        if (tier === 'tier3' && rowScore >= 70) show = false;
        if (search && !rowName.includes(search) && !rowEmail.includes(search) && !rowContact.toLowerCase().includes(search) && !rowRegion.toLowerCase().includes(search)) show = false;

        row.style.display = show ? '' : 'none';
        if (show) {
          visibleIdx++;
          const numCell = row.querySelector('td');
          if (numCell) numCell.textContent = String(visibleIdx);
        }
      });
    }

    regionFilter?.addEventListener('change', applyFilters);
    tierFilter?.addEventListener('change', applyFilters);
    searchInput?.addEventListener('input', applyFilters);

    // Email Draft Modal
    const modal = document.getElementById('email-modal');
    const closeBtn = document.getElementById('close-modal');
    const modalTo = document.getElementById('modal-to');
    const modalSubject = document.getElementById('modal-subject') as HTMLInputElement;
    const modalBody = document.getElementById('modal-body') as HTMLTextAreaElement;
    const copyBtn = document.getElementById('copy-email');
    const mailtoLink = document.getElementById('mailto-link') as HTMLAnchorElement;

    document.querySelectorAll('.draft-email-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const company = (btn as HTMLElement).dataset.company || '';
        const contact = (btn as HTMLElement).dataset.contact || '';
        const email = (btn as HTMLElement).dataset.email || '';
        const website = (btn as HTMLElement).dataset.website || '';
        const firstName = contact.split(' ')[0];

        if (modalTo) modalTo.textContent = `${contact} <${email}>`;
        if (modalSubject) modalSubject.value = `Partnership Opportunity — Returna x ${company}`;
        if (modalBody) modalBody.value = `Hi ${firstName},

I'm reaching out from Returna — we're building a network of Return Hubs across Europe to handle reverse logistics for consumer electronics returns.

We're looking for experienced ITAD partners like ${company} to join as Return Hubs in your region. The partnership involves:

• Processing returned consumer electronics through our platform
• Data sanitization and device grading
• Refurbishment or responsible recycling based on condition
• Revenue share on refurbished devices

Given ${company}'s capabilities${website ? ` (${website})` : ''}, I think there could be a strong fit. Would you be open to a brief call this week to explore this?

Best regards,
Kasper
Returna ApS`;

        const subject = encodeURIComponent(modalSubject.value);
        const body = encodeURIComponent(modalBody.value);
        if (mailtoLink) mailtoLink.href = `mailto:${email}?subject=${subject}&body=${body}`;

        modal?.classList.remove('hidden');
      });
    });

    closeBtn?.addEventListener('click', () => modal?.classList.add('hidden'));
    modal?.addEventListener('click', (e) => { if (e.target === modal) modal.classList.add('hidden'); });

    copyBtn?.addEventListener('click', () => {
      const text = `Subject: ${modalSubject.value}\n\n${modalBody.value}`;
      navigator.clipboard.writeText(text).then(() => {
        if (copyBtn) {
          copyBtn.textContent = '✓ Copied!';
          setTimeout(() => { copyBtn.textContent = 'Copy to Clipboard'; }, 2000);
        }
      });
    });

    // CSV Export
    document.getElementById('export-csv')?.addEventListener('click', () => {
      const visibleRows = Array.from(rows).filter(r => r.style.display !== 'none');
      let csv = 'Rank,Score,Company,Region,Contact,Title,Email,Website\n';
      visibleRows.forEach((row, idx) => {
        const cells = row.querySelectorAll('td');
        const score = row.dataset.score || '';
        const company = row.dataset.company || '';
        const region = row.dataset.region || '';
        const contactName = row.dataset.contactName || '';
        const email = row.dataset.email || '';
        const website = row.dataset.website || '';
        // Get title from the contact cell
        const titleEl = cells[4]?.querySelector('div:last-child');
        const title = titleEl?.textContent?.trim() || '';
        csv += `${idx+1},${score},"${company}","${region}","${contactName}","${title}","${email}","${website}"\n`;
      });
      const blob = new Blob([csv], { type: 'text/csv' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `outreach-plan-${new Date().toISOString().slice(0,10)}.csv`;
      a.click();
      URL.revokeObjectURL(url);
    });
  </script>
</Layout>
