---
import '../styles/global.css';

interface Props {
  title: string;
  activeNav?: string;
}

const { title, activeNav } = Astro.props;

const navItems = [
  { id: 'dashboard', label: 'Dashboard', href: '/', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0h4' },
  { id: 'features', label: 'Feature Map', href: '/features', icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4' },
  { id: 'roadmap', label: 'Roadmap', href: '/roadmap', icon: 'M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7' },
  { id: 'brainstorm', label: 'Brainstorm', href: '/brainstorm', icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z' },
  { id: 'design-system', label: 'Design System', href: '/design-system', icon: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01' },
  { id: 'audit', label: 'Audit', href: '/audit', icon: 'M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z' },
  { id: 'specs', label: 'Specs', href: '/specs', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z' },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Returna Product</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body class="min-h-screen">
  <div class="flex flex-col h-screen overflow-hidden">
    <!-- Mobile top bar -->
    <div class="no-print md:hidden flex-shrink-0 border-b flex items-center justify-between px-4 py-3" style="background: var(--bg-secondary); border-color: var(--border);">
      <button id="mobile-menu-btn" class="p-1.5 rounded-lg" style="color: var(--text-secondary);" aria-label="Open menu">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
      <div class="flex items-center gap-2">
        <img src="/returna-icon.svg" alt="Returna" class="w-6 h-6 rounded" />
        <span class="text-sm font-semibold" style="color: var(--text-primary);">Product</span>
      </div>
      <button id="theme-toggle-mobile" class="p-1.5 rounded-lg" style="color: var(--text-tertiary);" title="Toggle theme">
        <svg class="icon-sun-m" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
          <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg class="icon-moon-m" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
    </div>

    <!-- Desktop top bar -->
    <div class="no-print hidden md:flex flex-shrink-0 border-b items-center justify-between" style="background: var(--bg-secondary); border-color: var(--border);">
      <div class="w-60 flex-shrink-0 px-5 py-4 border-r flex items-center gap-3" style="border-color: var(--border);">
        <img src="/returna-icon.svg" alt="Returna" class="w-8 h-8 rounded" />
        <div>
          <div class="text-sm font-semibold" style="color: var(--text-primary);">Product</div>
          <div class="text-xs" style="color: var(--text-tertiary);">Returna ApS</div>
        </div>
      </div>
      <div class="flex-1 flex items-center justify-between px-6">
        <h1 class="text-base font-semibold" style="color: var(--text-primary);">{title}</h1>
        <button id="theme-toggle" class="p-2 rounded-lg border transition-colors" style="border-color: var(--border); color: var(--text-tertiary);" title="Toggle light/dark mode">
          <svg id="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
            <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
          <svg id="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile sidebar overlay -->
    <div id="sidebar-overlay" class="md:hidden fixed inset-0 z-40 hidden" style="background: rgba(0,0,0,0.5);">
      <aside id="mobile-sidebar" class="w-64 h-full flex flex-col transform -translate-x-full transition-transform duration-200" style="background: var(--bg-secondary);">
        <div class="flex items-center justify-between px-4 py-4 border-b" style="border-color: var(--border);">
          <div class="flex items-center gap-2">
            <img src="/returna-icon.svg" alt="Returna" class="w-7 h-7 rounded" />
            <span class="text-sm font-semibold" style="color: var(--text-primary);">Product</span>
          </div>
          <button id="mobile-close-btn" class="p-1.5 rounded-lg" style="color: var(--text-secondary);" aria-label="Close menu">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>
        <nav class="flex-1 px-3 py-4 overflow-y-auto">
          <ul class="space-y-0.5">
            {navItems.map(item => (
              <li>
                <a href={item.href}
                  class={`flex items-center gap-3 px-3 py-2.5 rounded text-sm transition-colors ${activeNav === item.id ? 'font-medium' : ''}`}
                  style={activeNav === item.id
                    ? `background: rgba(45, 107, 63, 0.12); color: var(--brand-green);`
                    : `color: var(--text-secondary);`
                  }>
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d={item.icon}/></svg>
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </aside>
    </div>

    <div class="flex flex-1 overflow-hidden">
      <!-- Desktop sidebar -->
      <aside class="no-print hidden md:flex w-60 flex-shrink-0 border-r flex-col overflow-y-auto" style="background: var(--bg-secondary); border-color: var(--border);">
        <nav class="flex-1 px-3 py-4">
          <ul class="space-y-0.5">
            {navItems.map(item => (
              <li>
                <a href={item.href}
                  class={`flex items-center gap-3 px-3 py-2 rounded text-sm transition-colors ${activeNav === item.id ? 'font-medium' : ''}`}
                  style={activeNav === item.id
                    ? `background: rgba(45, 107, 63, 0.12); color: var(--brand-green);`
                    : `color: var(--text-secondary);`
                  }
                  onmouseover="if(!this.classList.contains('font-medium'))this.style.background='var(--bg-elevated)'"
                  onmouseout="if(!this.classList.contains('font-medium'))this.style.background='transparent'">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d={item.icon}/></svg>
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
        <div class="px-5 py-4 border-t text-xs" style="border-color: var(--border); color: var(--text-tertiary);">
          Returna Product Portal
        </div>
      </aside>

      <!-- Main content -->
      <main class="flex-1 overflow-y-auto" id="main-content">
        <div class="max-w-6xl mx-auto px-4 md:px-8 py-6 md:py-8">
          <slot />
        </div>
      </main>
    </div>
  </div>

  <script is:inline>
    (function() {
      const saved = localStorage.getItem('theme') || 'dark';
      document.documentElement.setAttribute('data-theme', saved);
      function updateIcons(theme) {
        document.querySelectorAll('#icon-sun, .icon-sun-m').forEach(el => el.style.display = theme === 'dark' ? 'none' : 'block');
        document.querySelectorAll('#icon-moon, .icon-moon-m').forEach(el => el.style.display = theme === 'dark' ? 'block' : 'none');
      }
      updateIcons(saved);
      document.addEventListener('DOMContentLoaded', function() {
        updateIcons(document.documentElement.getAttribute('data-theme') || 'dark');
        function toggleTheme() {
          var current = document.documentElement.getAttribute('data-theme') || 'dark';
          var next = current === 'dark' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', next);
          localStorage.setItem('theme', next);
          updateIcons(next);
        }
        document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
        document.getElementById('theme-toggle-mobile')?.addEventListener('click', toggleTheme);
        var overlay = document.getElementById('sidebar-overlay');
        var sidebar = document.getElementById('mobile-sidebar');
        function openMenu() { overlay.classList.remove('hidden'); requestAnimationFrame(function() { sidebar.classList.remove('-translate-x-full'); }); }
        function closeMenu() { sidebar.classList.add('-translate-x-full'); setTimeout(function() { overlay.classList.add('hidden'); }, 200); }
        document.getElementById('mobile-menu-btn')?.addEventListener('click', openMenu);
        document.getElementById('mobile-close-btn')?.addEventListener('click', closeMenu);
        overlay?.addEventListener('click', function(e) { if (e.target === overlay) closeMenu(); });
      });
    })();
  </script>
</body>
</html>
